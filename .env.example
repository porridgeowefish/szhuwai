# ====================================
# 户外活动规划助手 - 环境变量配置模板
# ====================================
# 使用方法：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写你的 API 密钥和配置
# 3. 运行: docker-compose up -d

# ====================================
# API 密钥配置（必填）
# ====================================

# 和风天气 API 密钥
# 获取地址: https://dev.qweather.com/
QWEATHER_API_KEY=your_qweather_api_key_here

# 高德地图 API 密钥
# 获取地址: https://console.amap.com/
AMAP_API_KEY=your_amap_api_key_here

# 大模型 API 密钥（推荐 SiliconFlow）
# 获取地址: https://cloud.siliconflow.cn/
LLM_API_KEY=your_llm_api_key_here

# Tavily 搜索 API 密钥
# 获取地址: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ====================================
# 数据库配置
# ====================================

# MySQL 配置
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=outdoor_user
MYSQL_PASSWORD=outdoor_pass_2024
MYSQL_DATABASE=outdoor_planner
MYSQL_ROOT_PASSWORD=root_password_123

# MongoDB 配置
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=outdoor_planner
MONGO_USER=outdoor_user
MONGO_PASSWORD=outdoor_pass_2024

# ====================================
# JWT 配置
# ====================================

# JWT 签名密钥（生产环境请务必修改！）
JWT_SECRET_KEY=please-change-this-to-a-random-secret-key-in-production

# ====================================
# 阿里云短信配置
# ====================================

# 阿里云 AccessKey
# 获取地址: https://ram.console.aliyun.com/manage/ak
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# 短信签名名称（需要在阿里云短信服务中申请）
SMS_SIGN_NAME=户外规划助手

# 短信模板 ID（需要在阿里云短信服务中申请和审核）
SMS_TEMPLATE_REGISTER=your_register_template_id
SMS_TEMPLATE_LOGIN=your_login_template_id
SMS_TEMPLATE_BIND=your_bind_template_id
SMS_TEMPLATE_UNBIND=your_unbind_template_id
SMS_TEMPLATE_RESET_PASSWORD=your_reset_password_template_id

# ====================================
# 代理配置（可选）
# ====================================

# 如果你的网络需要代理，取消下面的注释
# PROXY_HTTP=http://127.0.0.1:7890
# PROXY_HTTPS=http://127.0.0.1:7890

# ====================================
# 端口配置（可选）
# ====================================

# 后端端口
BACKEND_PORT=8000

# 前端端口
FRONTEND_PORT=80
