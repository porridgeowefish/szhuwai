# API Keys for Outdoor Agent Planner
# Copy this file to .env and fill in your actual API keys

# 和风天气 API Key
# Get from: https://dev.qweather.com/
QWEATHER_API_KEY=your_qweather_api_key_here

# 和风天气开发者主机 (默认: devapi)
# 如需使用商业服务，请联系官方获取商业主机地址
WEATHER_DEVELOPER_HOST=devapi

# 高德地图 API Key
# Get from: https://lbs.amap.com/
AMAP_API_KEY=your_amap_api_key_here

# 大模型 API Key (支持 OpenAI/Anthropic)
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/
LLM_API_KEY=your_llm_api_key_here

# Tavily Search API Key
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Custom proxy settings
# PROXY_HTTP=http://127.0.0.1:7890
# PROXY_HTTPS=http://127.0.0.1:7890

# Optional: API timeouts (seconds)
API_TIMEOUT=10

# Optional: Retry attempts
API_RETRY=3

# Optional: Rate limit per minute
API_RATE_LIMIT=30